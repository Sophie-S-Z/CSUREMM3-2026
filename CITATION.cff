title: "What Can You Remember? Rescuing the Brain with Neural Mass Dynamics"
type: dataset
authors:
  - family-names: "Zhang"
    given-names: "Sophie"
    affiliation: "Columbia University in the City of New York"
  - family-names: "Hossain"
    given-names: "Rafia"
    affiliation: "Barnard College, Columbia University"
  - family-names: "Alisan"
